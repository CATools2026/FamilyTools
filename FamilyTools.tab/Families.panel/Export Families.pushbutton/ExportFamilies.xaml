<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Export Families"
    Height="640" Width="740"
    MinHeight="520" MinWidth="620"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    ShowInTaskbar="True"
    FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#7F77DD"/>
        <SolidColorBrush x:Key="AccentDark"  Color="#5B53B8"/>
        <SolidColorBrush x:Key="OrangeBrush" Color="#D85A30"/>
        <SolidColorBrush x:Key="OrangeDark"  Color="#B4471F"/>
        <SolidColorBrush x:Key="PanelBrush"  Color="#2E2547"/>
        <SolidColorBrush x:Key="FieldBrush"  Color="#241C39"/>
        <SolidColorBrush x:Key="TextBrush"   Color="#ECE9F7"/>
        <SolidColorBrush x:Key="MutedBrush"  Color="#A99FD0"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- accent (purple) button -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{StaticResource AccentDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- orange (primary export) button -->
        <Style x:Key="OrangeButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource OrangeBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{StaticResource OrangeDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#2A2040" Offset="0"/>
            <GradientStop Color="#1B1430" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Export Families"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock x:Name="summary_tb" Grid.Row="1" Text=""
                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,12"/>

        <!-- side-by-side selection panels -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Model -->
            <Border Grid.Column="0" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Model categories"
                               FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                    <CheckBox Grid.Row="1" x:Name="model_all" Content="Select all"
                              FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"
                              Margin="0,0,0,6" Click="model_all_click"/>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="model_list"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Annotation -->
            <Border Grid.Column="2" Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Annotation categories"
                               FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                    <CheckBox Grid.Row="1" x:Name="annot_all" Content="Select all"
                              FontWeight="SemiBold" Foreground="{StaticResource MutedBrush}"
                              Margin="0,0,0,6" Click="annot_all_click"/>
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="annot_list"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- destination folder -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Save to:" FontWeight="SemiBold"
                       VerticalAlignment="Center" Margin="0,0,10,0"/>
            <Border Grid.Column="1" Background="{StaticResource FieldBrush}"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                    CornerRadius="4">
                <TextBox x:Name="folder_tb" Background="Transparent" BorderThickness="0"
                         Foreground="{StaticResource TextBrush}" VerticalContentAlignment="Center"
                         Padding="8,0" Height="28" IsReadOnly="True"/>
            </Border>
            <Button Grid.Column="2" Content="Browse..." Width="90" Height="30" Margin="10,0,0,0"
                    Style="{StaticResource AccentButton}" Click="browse_click"/>
        </Grid>

        <!-- footer -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Bottom">
                <TextBlock x:Name="selcount_tb" Text="0 families selected"
                           Foreground="{StaticResource MutedBrush}" FontSize="12"/>
                <TextBlock Text="Copyright &#169; 2026 Chulan Adasuriya"
                           Foreground="{StaticResource MutedBrush}" FontSize="11"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Cancel" Width="110" Height="34" Margin="0,0,10,0"
                        Style="{StaticResource AccentButton}" Click="cancel_click"/>
                <Button Content="Export" Width="130" Height="34"
                        Style="{StaticResource OrangeButton}" Click="export_click"
                        IsDefault="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
